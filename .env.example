# LiveKit — get from cloud.livekit.io → Project Settings
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=
LIVEKIT_URL=wss://your-project.livekit.cloud
NEXT_PUBLIC_LIVEKIT_URL=wss://your-project.livekit.cloud

# Deepgram — STT (nova-3) — get from console.deepgram.com
DEEPGRAM_API_KEY=

# MiniMax — LLM (Text-01) + TTS (speech-02-turbo) — get from platform.minimax.io
MINIMAX_API_KEY=
MINIMAX_GROUP_ID=

# Moss — semantic video search
MOSS_PROJECT_ID=
MOSS_API_KEY=

# OpenAI — optional, tutor response fallback
OPENAI_API_KEY=

# Supabase — optional, future database
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Python agent: Next.js base URL for video status polling
NEXT_URL=http://localhost:3000
