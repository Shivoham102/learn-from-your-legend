# LiveKit — get from cloud.livekit.io → Project Settings
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=
LIVEKIT_URL=wss://your-project.livekit.cloud
NEXT_PUBLIC_LIVEKIT_URL=wss://your-project.livekit.cloud
NEXT_PUBLIC_USER_NAME=local

# Deepgram — STT (nova-3) — get from console.deepgram.com
DEEPGRAM_API_KEY=

# MiniMax — TTS (speech-02-turbo) — get from platform.minimax.io
MINIMAX_API_KEY=
MINIMAX_GROUP_ID=
MINIMAX_TTS_BASE_URL=https://api.minimax.io/v1/t2a_v2

# Qwen / DashScope — LLM via OpenAI-compatible API
DASHSCOPE_API_KEY=
QWEN_API_KEY=
OPENAI_BASE_HTTP_API_URL=https://dashscope-intl.aliyuncs.com/compatible-mode/v1
QWEN_BASE_URL=https://dashscope-intl.aliyuncs.com/compatible-mode/v1
QWEN_MODEL=qwen-turbo

# Qwen / DashScope — native HTTP TTS settings (not currently used by agent)
QWEN_TTS_BASE_URL=https://dashscope-intl.aliyuncs.com/api/v1
QWEN_TTS_MODEL=qwen3-tts-flash
QWEN_TTS_VOICE=Cherry

# Moss — semantic video search
MOSS_PROJECT_ID=
MOSS_API_KEY=

# OpenAI — optional, tutor response fallback
OPENAI_API_KEY=

# Supabase — optional, future database
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Python agent: Next.js base URL for video status polling
NEXT_URL=http://localhost:3000
