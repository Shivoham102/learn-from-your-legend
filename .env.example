# LiveKit — get from cloud.livekit.io → Project Settings
LIVEKIT_URL=wss://your-project.livekit.cloud
LIVEKIT_API_KEY=APIxxx
LIVEKIT_API_SECRET=xxx

# Deepgram — STT (nova-3) — get from console.deepgram.com
DEEPGRAM_API_KEY=xxx

# MiniMax — TTS (Speech-01) and LLM (Text-01)
MINIMAX_API_KEY=xxx
MINIMAX_GROUP_ID=xxx

# Moss — semantic search for video context
MOSS_API_KEY=xxx

# Next.js base URL (used by the Python agent to poll video status)
NEXT_URL=http://localhost:3000
