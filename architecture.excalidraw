      "boundElements": [],
      "updated": 1780841028750,
      "link": null,
      "locked": false,
      "text": "DentalAgent tools (called silently, Moss-grounded):\nget_current_segment \u00b7 search_video (Moss RAG \u2192 'dental_procedure')\nseek_to_segment \u00b7 resume_from_question\nplay/pause/rewind/forward/seek_video \u00b7 check_video_status\nvideo-control sent to browser over data channel\nloads segments JSON locally for live narration",
      "fontSize": 14,
      "fontFamily": 2,
      "textAlign": "center",
      "verticalAlign": "middle",
      "containerId": "7RgLdi8RDeWguzDB",
      "originalText": "DentalAgent tools (called silently, Moss-grounded):\nget_current_segment \u00b7 search_video (Moss RAG \u2192 'dental_procedure')\nseek_to_segment \u00b7 resume_from_question\nplay/pause/rewind/forward/seek_video \u00b7 check_video_status\nvideo-control sent to browser over data channel\nloads segments JSON locally for live narration",
      "lineHeight": 1.25,
      "baseline": 11
